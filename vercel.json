{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/bookings/:id?",
      "destination": "/api/bookings.js"
    },
    {
      "source": "/api/newsletter",
      "destination": "/api/newsletter.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
