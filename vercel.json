{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/bookings", "dest": "/api/bookings.ts" },
    { "src": "/api/newsletter", "dest": "/api/newsletter.ts" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
